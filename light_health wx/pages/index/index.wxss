.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 步数卡片 */
.step-card {
  background: linear-gradient(135deg, #00C896 0%, #00E6B3 100%);
  padding: 60rpx 40rpx;
  border-radius: 30rpx;
  text-align: center;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 200, 150, 0.3);
}

.step-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.step-number {
  display: block;
  font-size: 100rpx;
  color: white;
  font-weight: bold;
  margin: 20rpx 0;
}

.step-label {
  display: block;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 10rpx;
}

.step-date {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 操作区域 */
.action-area {
  margin-bottom: 30rpx;
}

.sync-btn {
  background: white;
  color: #00C896;
  border: 2rpx solid #00C896;
  border-radius: 15rpx;
  padding: 25rpx;
  font-size: 30rpx;
  font-weight: 500;
}

/* 图表区域 */
.chart-area {
  background: white;
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.chart-container {
  height: 300rpx;
  background: #f9f9f9;
  border-radius: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chart-placeholder {
  color: #999;
  font-size: 26rpx;
}

/* 记录列表 */
.record-list {
  background: white;
  padding: 30rpx;
  border-radius: 20rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #eee;
}

.record-type {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.record-duration {
  font-size: 28rpx;
  color: #00C896;
}

.delete-btn {
  font-size: 24rpx;
  color: #ff4d4f;
  padding: 4rpx 12rpx;
  border: 1rpx solid #ff4d4f;
  border-radius: 8rpx;
}
/* 添加记录区域 */
.add-record-area {
  margin-top: 30rpx;
  margin-bottom: 30rpx;
}

.add-record-btn {
  background: #00C896;
  color: white;
  border-radius: 15rpx;
  padding: 25rpx;
  font-size: 30rpx;
}

/* 列表头部（标题+清空按钮） */
.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-title-wrap {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.list-title-wrap .section-title {
  margin-bottom: 0;
}

.record-count {
  font-size: 22rpx;
  color: #999;
}

.clear-all-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 24rpx;
  background: #fff5f5;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #ff6b6b;
  border: 1rpx solid #ffe0e0;
  flex-shrink: 0;
}

.clear-all-btn:active {
  background: #ffe8e8;
  opacity: 0.85;
}

.clear-all-btn-disabled {
  background: #f5f5f5;
  color: #ccc;
  border-color: #eee;
  pointer-events: none;
}

.clear-icon {
  font-size: 26rpx;
  line-height: 1;
}

/* 列表项交互 */
.record-item {
  /* 增加长按反馈 */
  transition: background-color 0.2s;
}
.record-item:active {
  background-color: #f0f0f0;
}

.item-info {
  display: flex;
  flex-direction: column;
}

.record-time {
  font-size: 20rpx;
  color: #999;
  margin-top: 5rpx;
}

.empty-state {
  text-align: center;
  padding: 60rpx;
  color: #ccc;
}

.chart-area {
  height: 420rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}
ec-canvas {
  width: 100%;
  height: 360rpx;
}