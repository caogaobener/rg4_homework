.container {
  min-height: 100vh;
  padding: 32rpx;
  background: linear-gradient(180deg, #e8faf4 0%, #f5f5f5 280rpx);
  box-sizing: border-box;
}

/* 页头 */
.page-header {
  margin-bottom: 36rpx;
  padding: 16rpx 8rpx 0;
}

.page-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 2rpx;
}

.page-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #888;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 200, 150, 0.12);
}

.card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-row.column {
  flex-direction: column;
  align-items: flex-start;
}

.row-label {
  flex: 1;
  padding-right: 24rpx;
}

.label-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.label-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #aaa;
}

.remind-switch {
  transform: scale(0.95);
}

.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 32rpx 0;
}

/* 间隔输入 */
.interval-input-wrap {
  display: flex;
  align-items: center;
  width: 100%;
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  background: #f8fcfa;
  border: 2rpx solid #e0f5ee;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.interval-input {
  flex: 1;
  font-size: 40rpx;
  font-weight: 600;
  color: #00C896;
  height: 56rpx;
  line-height: 56rpx;
}

.interval-unit {
  font-size: 28rpx;
  color: #666;
  margin-left: 12rpx;
}

/* 状态 */
.status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.status-badge {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 40rpx;
  background: #f5f5f5;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 10rpx;
  background: #ccc;
}

.status-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #666;
}

/* 未开始 */
.status-idle {
  background: #f5f5f5;
}

.status-idle .status-dot {
  background: #bbb;
}

.status-idle .status-text {
  color: #888;
}

/* 已开启 */
.status-ready {
  background: #e8faf4;
}

.status-ready .status-dot {
  background: #00C896;
}

.status-ready .status-text {
  color: #00C896;
}

/* 提醒中 */
.status-active {
  background: #fff3e0;
}

.status-active .status-dot {
  background: #ff9800;
  animation: pulse 1.2s ease-in-out infinite;
}

.status-active .status-text {
  color: #e65100;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.5;
    transform: scale(0.85);
  }
}

/* 主按钮 */
.action-btn {
  width: 100% !important;
  height: 96rpx;
  line-height: 96rpx;
  margin: 0;
  padding: 0;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #00C896 0%, #00E6B3 100%);
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 12rpx 28rpx rgba(0, 200, 150, 0.35);
}

.action-btn::after {
  border: none;
}

.action-btn[disabled] {
  background: #e0e0e0;
  color: #aaa;
  box-shadow: none;
}

.action-btn-stop {
  background: linear-gradient(135deg, #ff7043 0%, #ff8a65 100%);
  box-shadow: 0 12rpx 28rpx rgba(255, 112, 67, 0.3);
}

/* 底部提示 */
.tips {
  display: flex;
  align-items: flex-start;
  margin-top: 32rpx;
  padding: 24rpx 28rpx;
  background: rgba(0, 200, 150, 0.08);
  border-radius: 16rpx;
}

.tips-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tips-text {
  font-size: 24rpx;
  color: #5a9e8a;
  line-height: 1.6;
}
