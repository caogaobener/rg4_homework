.container {
  padding: 30rpx;
}

.form {
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.input {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  border-bottom: 1rpx solid #e0e0e0;
  font-size: 28rpx;
}

.picker-input {
  color: #333;
}

.form-item {
  position: relative;
}

.unit {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  font-size: 24rpx;
  color: #999;
}

.submit-btn {
  width: 100%;
  background: #00C896;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
  border: none;
}

.submit-btn::after {
  border: none;
}

.calorie-row {
  position: relative;
}

.calorie-input {
  padding-right: 80rpx;
}

.estimate-btn {
  margin-top: 16rpx;
  background: #e8faf4;
  color: #00C896;
  border: 1rpx solid #00C896;
  font-size: 26rpx;
}

.field-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
}

.calorie-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #00C896;
}

.calorie-hint.formula {
  color: #999;
}
