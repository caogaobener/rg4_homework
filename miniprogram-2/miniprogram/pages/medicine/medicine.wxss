.top-section {
  padding: 20rpx 30rpx;
  background: #fff;
}

/* AI药师入口 */
.pharmacist-entry {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #07c160 0%, #10b981 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  color: #fff;
}

.pharmacist-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3);
  margin-right: 20rpx;
}

.pharmacist-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.pharmacist-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.pharmacist-desc {
  font-size: 24rpx;
  opacity: 0.9;
}

.arrow {
  font-size: 36rpx;
  opacity: 0.8;
}

