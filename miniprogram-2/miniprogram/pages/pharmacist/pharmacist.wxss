/* pages/pharmacist/pharmacist.wxss */
page {
  background: #f5f5f5;
}

.pharmacist-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 顶部 */
.header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.info {
  display: flex;
  flex-direction: column;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.status {
  font-size: 24rpx;
  color: #07c160;
}

/* 聊天区域 */
.chat-area {
  flex: 1;
  padding: 8rpx;
}

/* 欢迎消息 */
.welcome-msg {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
}

.welcome-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.welcome-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.feature-list text {
  font-size: 26rpx;
  color: #07c160;
}

.welcome-tip {
  display: block;
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-top: 20rpx;
}

/* 消息 */
.message {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-start;
  width: 100%;           /* 确保占满宽度 */
  box-sizing: border-box;
  padding: 0 20rpx;      /* 左右留边距 */
}

/* 用户消息：整体靠右 */
.message.user {
  justify-content: flex-end;
}

/* AI头像 */
.msg-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  flex-shrink: 0;        /* 防止压缩 */
  flex-grow: 0;          /* 防止拉伸 */
  display: block;        /* 确保是块级 */
}

.msg-avatar.left {
  margin-right: 16rpx;
}

.msg-avatar.right {
  margin-left: 16rpx;
  margin-right: 0;       /* 确保右边距为0 */
}

/* 消息内容 */
.msg-content {
  max-width: 65%;        /* 稍微减小，给头像留空间 */
  padding: 20rpx;
  border-radius: 16rpx;
  word-wrap: break-word;
}

/* AI消息内容 */
.msg-content.assistant {
  background: #fff;
}

/* 用户消息内容 */
.msg-content.user {
  background: #07c160;
}

/* 文字 */
.msg-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  word-break: break-all;
}

.msg-content.user .msg-text {
  color: #fff;
}

/* 时间 */
.msg-time {
  display: block;
  font-size: 20rpx;
  color: #999;
  margin-top: 10rpx;
}

.msg-content.user .msg-time {
  color: rgba(255,255,255,0.7);
}
/* 加载中 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  color: #999;
  font-size: 28rpx;
}

.dots text {
  animation: blink 1.4s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 0; }
  50% { opacity: 1; }
}

/* 快捷问题 */
.quick-questions {
  padding: 20rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.quick-title {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.quick-item {
  background: #f0f9f0;
  color: #07c160;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
}

/* 输入区域 */
.input-area {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #07c160;
  color: #fff;
  font-size: 28rpx;
  border-radius: 36rpx;
  margin-left: 16rpx;
}

.send-btn::after {
  border: none;
}

.send-btn[disabled] {
  background: #ccc;
}