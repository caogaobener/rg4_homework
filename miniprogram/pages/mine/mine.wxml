<view class="page">
  <!-- 顶部导航栏 -->
  <view class="nav-bar">
    <text class="nav-title">我的</text>
    <view class="nav-right">
      <image class="icon" src="/images/share.png"></image>
      <image class="icon" src="/images/menu.png"></image>
    </view>
  </view>

  <!-- 头像与昵称 -->
  <view class="profile-header">
    <view class="avatar">
      <image src="/images/tooth.png" mode="aspectFill"></image>
    </view>
    <text class="nickname">用户昵称</text>
  </view>

  <!-- 表单列表 -->
  <view class="form-list">
    <view class="form-item">
      <text class="label">身高</text>
      <input class="input" placeholder="请输入身高/cm" value="{{height}}" bindinput="onHeightInput" />
    </view>
    <view class="form-item">
      <text class="label">体重</text>
      <input class="input" placeholder="请输入体重/kg" value="{{weight}}" bindinput="onWeightInput" />
    </view>
    <view class="form-item">
      <text class="label">年龄</text>
      <input class="input" placeholder="请输入年龄" value="{{age}}" bindinput="onAgeInput" />
    </view>
    <view class="form-item">
      <text class="label">性别</text>
      <radio-group class="radio-group" bindchange="onGenderChange">
        <label class="radio-item">
          <radio value="女" checked="{{gender==='女'}}" />
          <text>女</text>
        </label>
        <label class="radio-item">
          <radio value="男" checked="{{gender==='男'}}" />
          <text>男</text>
        </label>
      </radio-group>
    </view>
    <view class="form-item">
      <text class="label">BMI</text>
      <text class="bmi-result">{{bmiResult || 'BMI计算结果'}}</text>
    </view>
  </view>

  <!-- 底部Tab栏 -->
  <view class="tab-bar">
    <view class="tab-item">
      <text>饮食</text>
    </view>
    <view class="tab-item">
      <text>运动</text>
    </view>
    <view class="tab-item">
      <text>用药</text>
    </view>
    <view class="tab-item">
      <text>AI</text>
    </view>
    <view class="tab-item active">
      <text>我的</text>
      <view class="active-line"></view>
    </view>
  </view>
</view>