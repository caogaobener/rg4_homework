.page {
  background: #fff;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 顶部导航 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  height: 90rpx;
  border-bottom: 1rpx solid #eee;
}
.nav-title {
  font-size: 34rpx;
  font-weight: 500;
}
.nav-right {
  position: absolute;
  right: 30rpx;
  display: flex;
  gap: 30rpx;
}
.nav-right .icon {
  width: 40rpx;
  height: 40rpx;
}

/* 头像区域 */
.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}
.avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: #a5d6b9; /* 浅绿色背景 */
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  margin-bottom: 30rpx;
}
.avatar image {
  width: 120rpx;
  height: 120rpx;
}
.nickname {
  font-size: 36rpx;
  font-weight: 500;
}

/* 表单列表 */
.form-list {
  flex: 1;
}
.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}
.label {
  font-size: 32rpx;
}
.input {
  text-align: right;
  color: #999;
  font-size: 32rpx;
}
.radio-group {
  display: flex;
  gap: 40rpx;
}
.radio-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.bmi-result {
  font-size: 32rpx;
  color: #333;
}

/* 底部Tab栏 */
.tab-bar {
  display: flex;
  justify-content: space-around;
  height: 100rpx;
  border-top: 1rpx solid #eee;
  background: #fff;
  padding-bottom: env(safe-area-inset-bottom);
}
.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333;
}
.tab-item.active {
  color: #39b54a; /* 绿色高亮 */
}
.active-line {
  width: 80rpx;
  height: 4rpx;
  background: #39b54a;
  margin-top: 8rpx;
}