/* pages/profile/profile.wxss */
page {
  background-color: #f5f5f5;
}

.profile-container {
  min-height: 100vh;
}

/* 用户信息头部 */
.user-header {
  background-color: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 50rpx;
}

.avatar-wrapper {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 30rpx;
  /* 去掉背景色，或设为白色 */
  background: #ffffff;
  /* 可选：加细边框 */
  border: 2rpx solid #f0f0f0;
}

.user-avatar {
  width: 160rpx;      /* 改成和容器一样大 */
  height: 160rpx;
  border-radius: 50%;  /* 图片本身也圆形 */
  display: block;
}

.user-name {
  font-size: 32rpx;
  color: #333333;
}

/* 表单列表 */
.form-list {
  background-color: #ffffff;
  margin-top: 20rpx;
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 30rpx;
  color: #333333;
  flex-shrink: 0;
  width: 120rpx;
}

.form-item input {
  text-align: right;
  font-size: 30rpx;
  color: #999999;
  flex: 1;
}

.bmi-text {
  font-size: 30rpx;
  color: #333333;
}

/* 性别单选 */
.gender-group {
  display: flex;
  align-items: center;
}

.radio-item {
  display: flex;
  align-items: center;
  margin-left: 30rpx;
}

.radio-circle {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #cccccc;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10rpx;
}

.radio-circle.active {
  border-color: #4CAF50;
}

.radio-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #4CAF50;
}

.radio-item text {
  font-size: 30rpx;
  color: #333333;
}

/* 保存按钮 */
.save-btn {
  margin: 60rpx 30rpx;
  background-color: #07c160;
  color: #ffffff;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 8rpx;
}

.save-btn::after {
  border: none;
}

/* 在 profile.wxss 末尾添加 */
.saved-tip {
  text-align: center;
  color: #07c160;
  font-size: 28rpx;
  margin-top: 40rpx;
}

/* 在 profile.wxss 末尾添加 */
.saved-section {
  margin: 40rpx 30rpx;
  text-align: center;
}

.saved-text {
  color: #07c160;
  font-size: 32rpx;
  font-weight: bold;
}

.local-tip {
  display: block;
  color: #999;
  font-size: 24rpx;
  margin-top: 10rpx;
}